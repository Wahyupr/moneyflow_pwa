# --- Database (self-hosted Postgres) ---
# Connection string to your Postgres instance. Keep secrets out of source control.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Set to "true" if your Postgres requires SSL (managed providers); leave unset for local.
DATABASE_SSL=
DATABASE_POOL_MAX=10

# --- Auth ---
# 32+ byte random secret used to sign session tokens and OTP hashes.
# Generate one with: openssl rand -base64 48
AUTH_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
# Verified sender on your Resend domain, e.g. "MoneyFlow <no-reply@yourdomain.com>".
EMAIL_FROM=

# --- Google OAuth (optional) ---
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <SITE_URL>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- App ---
# Base URL used to build OAuth redirect URLs. Set to your deployed origin in prod.
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Web Push / VAPID ---
# Generate a key pair once with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Also expose the public key to the browser so the SW can subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contact URL shown to push servers (mailto: or https:).
VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- Cron protection ---
# Optional static secret that must be sent as "Authorization: Bearer <CRON_SECRET>"
# when hitting POST /api/notifications/trigger from an external cron job.
CRON_SECRET=

# --- AI extraction (optional) ---
OPENAI_API_KEY=
AI_EXTRACTION_MODEL=gpt-5.5
AI_WORKER_POLL_INTERVAL_MS=5000

# --- AI voice parsing (optional) ---
# Used only when the rule-based voice parser is not confident (long/ambiguous
# input). If unset, the app always uses rules. Voice uses the AI gateway below;
# AI_VOICE_MODEL overrides the default model just for voice.
AI_API_KEY=
AI_BASE_URL=
AI_VOICE_MODEL=

# --- AI receipt OCR (Scan Struk / QRIS / bukti transfer / resi) ---
# OpenAI-compatible chat-completions gateway. Required for the receipt scan
# feature. The receipt parser also falls back to AI_API_KEY/AI_BASE_URL above
# if these are not set. AI_MODEL overrides the default receipt model.
GATEWAY_BASE_URL=
GATEWAY_API_KEY=
GATEWAY_MODEL_IMAGE=
GATEWAY_MODEL_VOICE=

# --- AI daily insight (Insight Dashboard harian + Laporan Excel) ---
# Provider terpisah untuk fitur insight agar bisa di-switch tanpa mengganggu
# receipt/voice path. Auto-detect format dari URL:
#   - URL mengandung "/anthropic" → Anthropic Messages API (/v1/messages)
#   - URL lainnya              → OpenAI Chat Completions (/chat/completions)
# Reuses AI_API_KEY di atas untuk autentikasi.
AI_BASE_URL_INSIGHT=
AI_MODEL_INSIGHT=glm-4.7

# Berapa jam setelah first_app_access_at sebelum auto-trigger insight harian
# dijalankan. Manual button tetap bisa kapan saja. Default 3.
INSIGHT_DELAY_HOURS=3




